{
  "default_policy": "mask_sensitive_by_default",
  "rules": [
    {
      "field_pattern": "parent_phone",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "support_manager"
      ]
    },
    {
      "field_pattern": "parent_email",
      "classification": "sensitive",
      "default_mask": "partial_email",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "support_manager"
      ]
    },
    {
      "field_pattern": "student_name",
      "classification": "sensitive",
      "default_mask": "masked_for_finance_default",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "school_onboarding_executive",
        "operations_executive",
        "support_executive",
        "exam_operations_manager"
      ]
    },
    {
      "field_pattern": "candidate_id",
      "classification": "internal",
      "default_mask": "visible",
      "unmask_roles": [
        "all_authorized"
      ]
    },
    {
      "field_pattern": "payment_reference",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "finance_admin",
        "company_admin"
      ]
    },
    {
      "field_pattern": "provider_payload",
      "classification": "sensitive",
      "default_mask": "hidden",
      "unmask_roles": [
        "security_admin_reviewer"
      ]
    },
    {
      "field_pattern": "answer_key",
      "classification": "restricted",
      "default_mask": "hidden",
      "unmask_roles": [
        "evaluation_manager",
        "results_approver",
        "security_admin_reviewer",
        "content_manager"
      ]
    },
    {
      "field_pattern": "raw_omr",
      "classification": "restricted",
      "default_mask": "hidden",
      "unmask_roles": [
        "evaluation_manager",
        "omr_import_operator",
        "security_admin_reviewer"
      ]
    },
    {
      "field_pattern": "internal_note",
      "classification": "internal",
      "default_mask": "hidden_from_school",
      "unmask_roles": [
        "support_manager",
        "company_admin",
        "security_admin_reviewer"
      ]
    },
    {
      "field_pattern": "private_file_url",
      "classification": "restricted",
      "default_mask": "never_return_raw",
      "unmask_roles": []
    },
    {
      "field_pattern": "signed_url",
      "classification": "restricted",
      "default_mask": "return_only_on_authorized_download",
      "unmask_roles": [
        "authorized_download_actor"
      ]
    },
    {
      "field_pattern": "audit_snapshot",
      "classification": "restricted",
      "default_mask": "hidden",
      "unmask_roles": [
        "security_admin_reviewer",
        "auditor_read_only_reviewer"
      ]
    },
    {
      "field_pattern": "coordinator_email",
      "classification": "sensitive",
      "default_mask": "partial_email",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "school_onboarding_executive",
        "operations_executive",
        "support_manager"
      ]
    },
    {
      "field_pattern": "coordinator_phone",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "school_onboarding_executive",
        "operations_executive",
        "support_manager"
      ]
    },
    {
      "field_pattern": "coordinator_mobile",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "school_onboarding_executive",
        "operations_executive",
        "support_manager"
      ]
    },
    {
      "field_pattern": "document_file",
      "classification": "restricted",
      "default_mask": "never_return_raw",
      "unmask_roles": []
    },
    {
      "field_pattern": "setting_value",
      "classification": "restricted",
      "default_mask": "hidden",
      "unmask_roles": [
        "security_admin_reviewer"
      ]
    },
    {
      "field_pattern": "channel_address",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "support_manager"
      ]
    },
    {
      "field_pattern": "recipient_email",
      "classification": "sensitive",
      "default_mask": "partial_email",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "support_manager"
      ]
    },
    {
      "field_pattern": "recipient_phone",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "company_admin",
        "operations_head",
        "support_manager"
      ]
    },
    {
      "field_pattern": "provider_reference",
      "classification": "sensitive",
      "default_mask": "last_4_only",
      "unmask_roles": [
        "finance_admin",
        "company_admin"
      ]
    },
    {
      "field_pattern": "response_payload",
      "classification": "restricted",
      "default_mask": "hidden",
      "unmask_roles": [
        "evaluation_manager",
        "omr_import_operator",
        "security_admin_reviewer"
      ]
    }
  ]
}
