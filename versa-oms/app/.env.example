# Versa Olympiads environment template

APP_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgres://user:password@localhost:5432/versa

# Supabase (local defaults are used automatically if these are unset).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_me_service_role_key
SESSION_SECRET=replace_me
INTERNAL_API_SECRET=replace_me
STORAGE_PRIVATE_BUCKET=versa-private
SIGNED_URL_TTL_SECONDS=900

# Feature flags default to conservative values in production.
FEATURE_SCHOOL_PORTAL_ENABLED=true
FEATURE_PAYMENT_GATEWAY_LIVE_ENABLED=false
FEATURE_EXAM_MATERIAL_RELEASE_ENABLED=false
FEATURE_RESULT_PUBLICATION_ENABLED=false
FEATURE_PUBLIC_CERTIFICATE_VERIFICATION_ENABLED=false
FEATURE_SENSITIVE_EXPORTS_ENABLED=false
