{
  "name": "versa-spec-playbook-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable scope-to-questionnaire-to-module-spec generator for Versa Olympiads.",
  "scripts": {
    "questionnaire": "python scripts/generate_questionnaire.py",
    "source": "python scripts/build_source_of_truth_csv.py",
    "registry": "python scripts/build_module_registry.py",
    "module": "python scripts/generate_module_spec.py --zip",
    "validate": "python scripts/validate_module_spec.py",
    "summary": "python scripts/update_completed_pending_summary.py",
    "package:all": "python scripts/package_all_modules_zip.py"
  }
}
