{
  "default_mode": "hybrid",
  "default_output_root": "outputs",
  "default_module_registry": "inputs/module_registry.csv",
  "default_scope_file": "inputs/scope.md",
  "default_questionnaire_file": "outputs/source_of_truth/questionnaire.csv",
  "default_source_of_truth_file": "outputs/source_of_truth/answered_source_of_truth.csv",
  "state_file": "state/current_company_portal_state.json",
  "strict_validation": true,
  "zip_after_generation": true,
  "llm_provider_env": {
    "provider": "OPENAI",
    "api_key": "OPENAI_API_KEY",
    "model": "OPENAI_MODEL"
  }
}