{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Versa Audit Event",
  "type": "object",
  "required": [
    "audit_event_id",
    "timestamp",
    "source_module",
    "action",
    "actor",
    "entity",
    "risk"
  ],
  "properties": {
    "audit_event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_module": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "staff",
            "school",
            "system",
            "public"
          ]
        },
        "role_snapshot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scope_snapshot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "required": [
        "entity_type",
        "entity_id"
      ],
      "properties": {
        "entity_type": {
          "type": "string"
        },
        "entity_id": {
          "type": "string"
        }
      }
    },
    "previous_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "new_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "request_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "event_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "safe_snapshot": {
      "type": "object"
    }
  }
}
