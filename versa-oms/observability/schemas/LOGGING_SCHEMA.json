{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Versa Application Log Event",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "event_type",
    "request_id",
    "module_id",
    "message"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warn",
        "error",
        "critical"
      ]
    },
    "event_type": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "module_id": {
      "type": "string"
    },
    "actor_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "staff",
        "school",
        "system",
        "public",
        null
      ]
    },
    "actor_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "route": {
      "type": [
        "string",
        "null"
      ]
    },
    "method": {
      "type": [
        "string",
        "null"
      ]
    },
    "status_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "duration_ms": {
      "type": [
        "number",
        "null"
      ]
    },
    "entity_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "message": {
      "type": "string"
    },
    "safe_context": {
      "type": "object"
    },
    "redaction_applied": {
      "type": "boolean"
    },
    "release_id": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
