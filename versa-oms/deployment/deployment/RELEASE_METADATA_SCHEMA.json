{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Versa Release Metadata",
  "type": "object",
  "required": [
    "release_id",
    "environment",
    "commit_sha",
    "created_at",
    "status",
    "rollback_ref",
    "smoke_test_status"
  ],
  "properties": {
    "release_id": {
      "type": "string",
      "pattern": "^REL-[0-9]{8}-[0-9]{3}$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "commit_sha": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "staging_deployed",
        "production_approved",
        "production_deployed",
        "rolled_back",
        "failed"
      ]
    },
    "affected_modules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "feature_flag_diff": {
      "type": "object"
    },
    "rollback_ref": {
      "type": "string"
    },
    "smoke_test_status": {
      "type": "string",
      "enum": [
        "not_run",
        "passed",
        "failed"
      ]
    },
    "approved_by": {
      "type": "string"
    }
  }
}
