{
  "module_id": "school_crm",
  "route": "schools/crm",
  "title": "School CRM",
  "eyebrow": "staff · school_crm",
  "endpoint": "/api/staff/schools/crm",
  "status_key": "lead_status",
  "columns": [
    { "key": "lead_code", "label": "Lead code" },
    { "key": "school_name", "label": "School" },
    { "key": "city", "label": "City" },
    { "key": "stage", "label": "Stage" },
    { "key": "lead_status", "label": "Status" }
  ],
  "create_fields": [
    { "key": "school_name", "label": "School name", "required": true },
    { "key": "city", "label": "City", "required": true },
    { "key": "state", "label": "State", "type": "select", "required": true,
      "options": ["Andhra Pradesh", "Arunachal Pradesh", "Assam", "Bihar", "Chhattisgarh", "Goa", "Gujarat", "Haryana", "Himachal Pradesh", "Jharkhand", "Karnataka", "Kerala", "Madhya Pradesh", "Maharashtra", "Manipur", "Meghalaya", "Mizoram", "Nagaland", "Odisha", "Punjab", "Rajasthan", "Sikkim", "Tamil Nadu", "Telangana", "Tripura", "Uttar Pradesh", "Uttarakhand", "West Bengal", "Andaman and Nicobar Islands", "Chandigarh", "Dadra and Nagar Haveli and Daman and Diu", "Delhi", "Jammu and Kashmir", "Ladakh", "Lakshadweep", "Puducherry", "Other"] },
    { "key": "country", "label": "Country", "type": "select", "required": true, "default": "India",
      "options": ["India", "United Arab Emirates", "Saudi Arabia", "Qatar", "Oman", "Kuwait", "Bahrain", "Singapore", "Nepal", "Bhutan", "Sri Lanka", "Other"] },
    { "key": "lead_source", "label": "Lead source", "type": "select", "required": true,
      "options": ["manual", "csv_import", "xlsx_import", "website", "referral", "event", "social", "email_campaign", "partner", "other"] },
    { "key": "board", "label": "Board", "type": "select",
      "options": ["CBSE", "ICSE", "State Board", "Cambridge", "IB", "Other"] },
    { "key": "coordinator_name", "label": "Coordinator name" },
    { "key": "email", "label": "Email", "type": "email" },
    { "key": "phone", "label": "Phone", "type": "tel" },
    { "key": "expected_student_count", "label": "Expected students", "type": "number" }
  ],
  "row_select": {
    "key": "stage", "sub_path": "stage", "lock_statuses": ["converted", "lost"],
    "options": ["new_lead", "contacted", "brochure_sent", "demo_scheduled", "demo_completed", "proposal_sent", "follow_up", "payment_pending", "converted", "lost"]
  },
  "detail_panel": {
    "key": "comms", "label": "Comms", "sub_path": "interactions",
    "list_columns": ["interaction_at", "interaction_type", "summary", "outcome"],
    "add_fields": [
      { "key": "interaction_type", "label": "Type", "type": "select", "required": true, "options": ["call", "email", "whatsapp_manual", "meeting", "demo", "proposal", "note"] },
      { "key": "summary", "label": "Summary", "type": "textarea", "required": true, "placeholder": "What happened on this interaction?" },
      { "key": "outcome", "label": "Outcome", "type": "select", "options": ["positive", "neutral", "negative", "no_response", "reschedule", "converted", "lost", "other"] },
      { "key": "next_followup_at", "label": "Next follow-up", "type": "date" }
    ],
    "edit_fields": [
      { "key": "interaction_type", "label": "Type", "type": "select", "required": true, "options": ["call", "email", "whatsapp_manual", "meeting", "demo", "proposal", "note"] },
      { "key": "summary", "label": "Summary", "type": "textarea", "required": true },
      { "key": "outcome", "label": "Outcome", "type": "select", "options": ["positive", "neutral", "negative", "no_response", "reschedule", "converted", "lost", "other"] },
      { "key": "next_followup_at", "label": "Next follow-up", "type": "date" },
      { "key": "reason", "label": "Reason for edit", "type": "textarea", "required": true, "placeholder": "Why are you changing this interaction?" }
    ]
  },
  "custom_actions": [
    { "key": "assign", "label": "Assign", "sub_path": "assign", "lock_statuses": ["converted", "lost"],
      "fields": [{ "key": "lead_owner_id", "label": "Owner staff UUID", "required": true }] },
    { "key": "convert", "label": "Convert", "variant": "blue", "sub_path": "convert", "lock_statuses": ["converted", "lost"],
      "confirm_title": "Convert to school",
      "confirm_body": "This school becomes a customer. It moves from your sales pipeline to the onboarding team, who will check its details and get it ready to run exams.",
      "confirm_warn": "This can't be undone." },
    { "key": "lost", "label": "Lost", "sub_path": "lost", "lock_statuses": ["converted", "lost"],
      "fields": [{ "key": "reason", "label": "Lost reason", "required": true }] }
  ],
  "import_config": {
    "sub_path": "import", "payload_key": "leads", "label": "Import",
    "columns": ["school_name", "city", "email", "phone"],
    "placeholder": "Delhi Public School, Delhi, dps@x.com, 9876543210"
  },
  "toolbar": {
    "facet": { "key": "stage", "options": [
      { "value": "new_lead", "label": "New" },
      { "value": "contacted", "label": "Contacted" },
      { "value": "brochure_sent", "label": "Brochure" },
      { "value": "demo_scheduled", "label": "Demo set" },
      { "value": "demo_completed", "label": "Demo done" },
      { "value": "proposal_sent", "label": "Proposal" },
      { "value": "follow_up", "label": "Follow-up" },
      { "value": "payment_pending", "label": "Payment" },
      { "value": "converted", "label": "Converted" },
      { "value": "lost", "label": "Lost" }
    ] },
    "filters": [
      { "key": "lead_status", "label": "Status", "options": ["active", "stale", "duplicate_review", "lost"] },
      { "key": "lead_source", "label": "Source", "options": ["manual", "csv_import", "xlsx_import", "website", "referral", "event", "social", "email_campaign", "partner", "other"] }
    ],
    "search": true,
    "owner": true,
    "sort": [
      { "value": "created_at:desc", "label": "Newest" },
      { "value": "followup_date:asc", "label": "Follow-up due" },
      { "value": "estimated_value:desc", "label": "Highest value" }
    ]
  }
}
