{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "versa-oms/spec/rules/rule.schema.json",
  "title": "Versa OMS business rule",
  "description": "One declarative business rule. Authored centrally, compiled per-module by gen_rules.py. See spec/rules/RULE_TAXONOMY.md.",
  "type": "object",
  "required": ["id", "module", "action", "type", "when", "then", "source"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+\\.[a-z0-9_*]+\\.[a-z0-9_]+$", "description": "<module>.<action>.<name>" },
    "module": { "type": "string" },
    "action": { "type": "string", "description": "create | update | read | a transition name | *" },
    "type": { "enum": ["validation", "scoping", "precondition", "eligibility", "approval", "effect", "masking", "lifecycle"] },
    "when": { "type": "object", "description": "type-specific condition (e.g. validation: {field, condition, params})" },
    "then": { "type": "object", "description": "type-specific consequence (e.g. validation: {error:{field,code,message}})" },
    "source": { "type": "string", "description": "provenance: canonical:<table>.<col> | BRD:<ref> | brain:<doc> | workflow:<id> | effects:<chain> | permissions" },
    "severity": { "enum": ["error", "warning"], "default": "error" },
    "enabled": { "type": "boolean", "default": true }
  }
}
