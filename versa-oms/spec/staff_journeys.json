{
  "_source": "structured from spec/STAFF_JOURNEYS.md (FROZEN from BRD §06/§11/§03). gen_portal reads this.",
  "_scope_note": "scope=all -> staff see every school's records (no school filter). Role-gating wires at auth-last.",
  "portal": {
    "name": "staff",
    "dir": "staff",
    "brand": "Operations",
    "navlabel": "Operations",
    "scoped": false
  },
  "journeys": [
    {
      "id": "OJ1",
      "title": "Operations dashboard",
      "desc": "Every school and where each participation is in the pipeline.",
      "icon": "grid",
      "shape": "list",
      "entity": "participations",
      "scope": "all",
      "cols": [
        "participation_code",
        "status"
      ]
    },
    {
      "id": "OJ-O1",
      "title": "Import directory",
      "desc": "Upload any school list (CSV/XLSX) — map columns, review duplicates, import as prospects.",
      "icon": "upload",
      "shape": "import",
      "entity": "school_imports",
      "scope": "all",
      "create_status": "uploaded",
      "create_label": "New import",
      "actions": [
        "validate_rows",
        "complete_import",
        "fail_import"
      ],
      "group": "CRM · Outreach"
    },
    {
      "id": "OJ-O2",
      "title": "School directory",
      "desc": "Every school — prospects, leads, and onboarding to approved. Add or correct, register interest, submit registration, then approve or block.",
      "icon": "globe",
      "shape": "manage",
      "entity": "schools",
      "scope": "all",
      "create_status": "prospect",
      "create_label": "Add school",
      "actions": [
        "register_interest",
        "submit_registration",
        "approve_school",
        "block_school"
      ],
      "group": "CRM · Outreach",
      "substeps": [
        "Add / correct — bulk via Import, or add one (starts as a prospect)",
        "Register interest — convert a prospect to a lead (prospect -> lead)",
        "Submit registration — lead -> registered (creates the participation)",
        "Approve / block — approve_school (auto-opens student upload) or block_school"
      ],
      "cols": [
        "name",
        "city",
        "state",
        "coordinator_email",
        "status",
        "last_contacted_at"
      ],
      "filters": [
        "status",
        "source",
        "state",
        "unsubscribed"
      ],
      "deletable": "prospect"
    },
    {
      "id": "OJ-O3",
      "title": "Email campaigns",
      "desc": "Create campaigns, target the directory, schedule + send via the email gateway.",
      "icon": "mail",
      "shape": "manage",
      "entity": "email_campaigns",
      "scope": "all",
      "create_status": "draft",
      "create_label": "New campaign",
      "actions": [
        "schedule",
        "start_send",
        "finish_send",
        "pause",
        "cancel"
      ],
      "group": "CRM · Outreach"
    },
    {
      "id": "OJ-O4",
      "title": "Sends & tracking",
      "desc": "Per-school send status — delivered, opened, bounced, unsubscribed.",
      "icon": "chart",
      "shape": "list",
      "entity": "email_sends",
      "scope": "all",
      "cols": [
        "send_ref",
        "email",
        "status"
      ],
      "group": "CRM · Outreach"
    },
    {
      "id": "OJ3",
      "title": "Reconcile payments",
      "desc": "Confirm and reconcile school payments.",
      "icon": "key",
      "shape": "manage",
      "entity": "payments",
      "scope": "all",
      "actions": [
        "manual_confirm",
        "reconcile",
        "reverse"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ4",
      "title": "Exam slots",
      "desc": "Publish and manage the slots schools can choose.",
      "icon": "calendar",
      "shape": "manage",
      "entity": "exam_slots",
      "scope": "all",
      "actions": [
        "capacity_full",
        "change_slot"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ5",
      "title": "Release materials",
      "desc": "Approve, schedule and release question papers.",
      "icon": "download",
      "shape": "manage",
      "entity": "exam_materials",
      "scope": "all",
      "actions": [
        "approve_material",
        "schedule_release",
        "release_when_due",
        "revoke"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ6",
      "title": "Receive couriers",
      "desc": "Confirm receipt of returned answer sheets.",
      "icon": "route",
      "shape": "manage",
      "entity": "courier_batches",
      "scope": "all",
      "actions": [
        "confirm_receipt",
        "close_batch"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ7",
      "title": "OMR import & match",
      "desc": "Import scans, match candidates, approve or reject.",
      "icon": "upload",
      "shape": "manage",
      "entity": "omr_imports",
      "scope": "all",
      "actions": [
        "upload_omr",
        "validate_import",
        "approve_import",
        "reject_import"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ8",
      "title": "Approve & publish results",
      "desc": "Review, approve, publish, withhold or correct results.",
      "icon": "chart",
      "shape": "manage",
      "entity": "results",
      "scope": "all",
      "actions": [
        "review_results",
        "approve",
        "publish",
        "withhold",
        "correct"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ9",
      "title": "Generate certificates",
      "desc": "Issue and revoke certificates.",
      "icon": "file",
      "shape": "manage",
      "entity": "certificates",
      "scope": "all",
      "actions": [
        "issue",
        "revoke"
      ],
      "group": "Exam pipeline"
    }
  ]
}
