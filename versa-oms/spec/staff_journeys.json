{
  "_source": "structured from spec/STAFF_JOURNEYS.md (FROZEN from BRD §06/§11/§03). gen_portal reads this.",
  "_scope_note": "scope=all -> staff see every school's records (no school filter). Role-gating wires at auth-last.",
  "portal": {
    "name": "staff",
    "dir": "staff",
    "brand": "Operations",
    "navlabel": "Operations",
    "scoped": false
  },
  "journeys": [
    {
      "id": "OJ1",
      "title": "Operations dashboard",
      "desc": "Every school and where each participation is in the pipeline.",
      "icon": "grid",
      "shape": "list",
      "entity": "participations",
      "scope": "all",
      "cols": [
        "participation_code",
        "status"
      ]
    },
    {
      "id": "OJ-AN",
      "title": "Analytics",
      "desc": "Live performance analytics — schools, students, average and pass rates, and medals per olympiad.",
      "icon": "bar-chart",
      "shape": "analytics",
      "entity": "results",
      "scope": "all",
      "group": "Setup"
    },
    {
      "id": "OJ-OLY",
      "title": "Olympiads",
      "desc": "Create and manage olympiads — subjects, eligibility, registration windows, fees. Open registration when ready; only OPEN olympiads within their registration window appear on the public registration form.",
      "icon": "award",
      "shape": "manage",
      "entity": "olympiads",
      "scope": "all",
      "create_status": "draft",
      "create_label": "Create olympiad",
      "actions": [
        "open_registration",
        "close_registration",
        "reopen_registration",
        "archive"
      ],
      "group": "Setup",
      "cols": [
        "name",
        "subject",
        "academic_year",
        "status",
        "registration_open_at",
        "registration_close_at"
      ]
    },
    {
      "id": "OJ-AK",
      "title": "Answer keys",
      "desc": "Author answer keys per olympiad and grade — correct option + marks per question; publish to enable scoring. Negative marking is set on the olympiad.",
      "icon": "key",
      "shape": "manage",
      "entity": "answer_keys",
      "scope": "all",
      "create_status": "draft",
      "create_label": "New answer key",
      "actions": [
        "publish",
        "revise",
        "archive"
      ],
      "group": "Setup",
      "cols": [
        "answer_key_code",
        "olympiad_id",
        "grade",
        "total_questions",
        "status"
      ]
    },
    {
      "id": "OJ-SR",
      "title": "Study resources",
      "desc": "Syllabus, sample papers and guides per olympiad/grade. Publish to make them downloadable.",
      "icon": "book-open",
      "shape": "manage",
      "entity": "study_resources",
      "scope": "all",
      "create_status": "draft",
      "create_label": "Add resource",
      "actions": [
        "publish",
        "unpublish",
        "archive"
      ],
      "group": "Setup",
      "cols": [
        "resource_code",
        "olympiad_id",
        "grade",
        "kind",
        "title",
        "status"
      ]
    },
    {
      "id": "OJ-O1",
      "title": "Import directory",
      "desc": "Upload any school list (CSV/XLSX) — map columns, review duplicates, import as prospects.",
      "icon": "upload",
      "shape": "import",
      "entity": "school_imports",
      "scope": "all",
      "create_status": "uploaded",
      "create_label": "New import",
      "actions": [
        "validate_rows",
        "complete_import",
        "fail_import"
      ],
      "group": "CRM · Outreach"
    },
    {
      "id": "OJ-O2",
      "title": "School directory",
      "desc": "Every school in one place — search, filter, correct details, and select rows to add to a campaign. Staff: approve / reject / block / activate / deactivate / unsubscribe. Schools register interest and submit their own registration via the outreach email link.",
      "icon": "globe",
      "shape": "manage",
      "entity": "schools",
      "scope": "all",
      "create_status": "prospect",
      "create_label": "Add school",
      "actions": [
        "approve_school",
        "reject_school",
        "block_school",
        "deactivate",
        "activate"
      ],
      "group": "CRM · Outreach",
      "cols": [
        "name",
        "city",
        "state",
        "coordinator_email",
        "status",
        "last_contacted_at"
      ],
      "filters": [
        "status",
        "source",
        "state",
        "unsubscribed"
      ],
      "deletable": "prospect",
      "bulk_action": {
        "label": "Create campaign",
        "to": "OJ-O3B.html",
        "key": "campaign_targets"
      },
      "create_defaults": {
        "source": "manual"
      },
      "toggles": [
        {
          "field": "unsubscribed",
          "on": "Unsubscribe",
          "off": "Resubscribe"
        }
      ],
      "tabs": [
        {
          "label": "Awaiting approval",
          "status": [
            "registered"
          ]
        },
        {
          "label": "Leads",
          "status": [
            "prospect",
            "lead"
          ]
        },
        {
          "label": "Approved",
          "status": [
            "approved"
          ]
        },
        {
          "label": "All",
          "status": []
        }
      ]
    },
    {
      "id": "OJ-O3",
      "title": "Email campaigns",
      "desc": "Compose a campaign (subject + HTML body with merge tags) and SEND it to selected schools — or CREATE it in Brevo to finish + send there. Targets come from the School directory selection.",
      "icon": "mail",
      "shape": "manage",
      "entity": "email_campaigns",
      "scope": "all",
      "create_status": "draft",
      "create_label": "New campaign",
      "actions": [
        "start_send",
        "schedule",
        "send_scheduled",
        "finish_send",
        "pause",
        "cancel"
      ],
      "group": "CRM · Outreach",
      "cols": [
        "name",
        "subject",
        "status",
        "sent_count"
      ],
      "receive": {
        "key": "campaign_targets",
        "field": "target_ids",
        "noun": "schools"
      },
      "builder": "OJ-O3B.html",
      "tabs": [
        {
          "label": "Drafts",
          "status": [
            "draft"
          ]
        },
        {
          "label": "Scheduled",
          "status": [
            "scheduled"
          ]
        },
        {
          "label": "Sent",
          "status": [
            "sending",
            "sent"
          ]
        },
        {
          "label": "All",
          "status": []
        }
      ]
    },
    {
      "id": "OJ-O3B",
      "title": "Campaign builder",
      "desc": "Compose an email campaign with a live desktop/mobile preview, choose recipients, then send now, schedule, or hand off to Brevo.",
      "icon": "mail-plus",
      "shape": "builder",
      "entity": "email_campaigns",
      "scope": "all",
      "group": "CRM · Outreach",
      "compose": [
        {
          "kind": "text",
          "field": "name",
          "label": "Campaign name",
          "placeholder": "Internal name"
        },
        {
          "kind": "recipients",
          "label": "To (recipients)",
          "prefill": "name"
        },
        {
          "kind": "emails",
          "field": "recipient_emails",
          "label": "Email IDs",
          "prefill": "coordinator_email"
        },
        {
          "kind": "text",
          "field": "subject",
          "label": "Email subject",
          "merge": true,
          "placeholder": "Hi {{school_name}} — your invite"
        },
        {
          "kind": "templates"
        },
        {
          "kind": "body",
          "field": "html_content"
        },
        {
          "kind": "attachments",
          "field": "attachments"
        },
        {
          "kind": "preview"
        }
      ],
      "send": [
        {
          "key": "now",
          "label": "Send now",
          "icon": "send"
        },
        {
          "key": "schedule",
          "label": "Schedule",
          "icon": "file-clock"
        },
        {
          "key": "draft",
          "label": "Save draft",
          "icon": "save"
        }
      ],
      "send_validation": [
        {
          "check": "recipients",
          "message": "Add at least one recipient email in Email IDs"
        },
        {
          "check": "field",
          "field": "subject",
          "message": "Add an email subject"
        },
        {
          "check": "body_or_attachment",
          "message": "Add an email body, or attach a file"
        }
      ]
    },
    {
      "id": "OJ-O4",
      "title": "Sends & tracking",
      "desc": "Per-school send status — delivered, opened, bounced, unsubscribed.",
      "icon": "chart",
      "shape": "list",
      "entity": "email_sends",
      "scope": "all",
      "cols": [
        "send_ref",
        "email",
        "status"
      ],
      "group": "CRM · Outreach"
    },
    {
      "id": "OJ3",
      "title": "Reconcile payments",
      "desc": "Confirm and reconcile school payments.",
      "icon": "key",
      "shape": "manage",
      "entity": "payments",
      "scope": "all",
      "actions": [
        "manual_confirm",
        "reconcile",
        "reverse"
      ],
      "group": "Exam pipeline",
      "cols": [
        "payment_code",
        "school_id",
        "expected_amount",
        "received_amount",
        "status",
        "reconciled_at"
      ]
    },
    {
      "id": "OJ4",
      "title": "Exam slots",
      "desc": "Publish and manage the slots schools can choose.",
      "icon": "calendar",
      "shape": "manage",
      "entity": "exam_slots",
      "scope": "all",
      "actions": [
        "capacity_full",
        "change_slot"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ5",
      "title": "Release materials",
      "desc": "Approve, schedule and release question papers.",
      "icon": "download",
      "shape": "manage",
      "entity": "exam_materials",
      "scope": "all",
      "actions": [
        "approve_material",
        "schedule_release",
        "release_when_due",
        "revoke"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ-AD",
      "title": "Admit cards",
      "desc": "Admit cards generated per student on roster finalisation — candidate id, exam slot, venue. Issue to release to schools.",
      "icon": "credit-card",
      "shape": "manage",
      "entity": "admit_cards",
      "scope": "all",
      "create_label": "Add admit card",
      "create_status": "generated",
      "actions": [
        "issue"
      ],
      "group": "Exam logistics",
      "cols": [
        "admit_card_code",
        "candidate_id",
        "venue",
        "exam_slot_id",
        "status"
      ]
    },
    {
      "id": "OJ6",
      "title": "Receive couriers",
      "desc": "Confirm receipt of returned answer sheets.",
      "icon": "route",
      "shape": "manage",
      "entity": "courier_batches",
      "scope": "all",
      "actions": [
        "confirm_receipt",
        "close_batch"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ-ATT",
      "title": "Exam attendance",
      "desc": "Mark exam-day attendance per student. Absent students are excluded from ranking.",
      "icon": "user-check",
      "shape": "manage",
      "entity": "students",
      "scope": "all",
      "group": "Evaluation",
      "cols": [
        "candidate_id",
        "student_name",
        "grade",
        "exam_attendance"
      ]
    },
    {
      "id": "OJ7",
      "title": "OMR import & match",
      "desc": "Import scans, match candidates, approve or reject.",
      "icon": "upload",
      "shape": "manage",
      "entity": "omr_imports",
      "scope": "all",
      "actions": [
        "upload_omr",
        "validate_import",
        "approve_import",
        "reject_import"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ8",
      "title": "Approve & publish results",
      "desc": "Review, approve, publish, withhold or correct results.",
      "icon": "chart",
      "shape": "manage",
      "entity": "results",
      "scope": "all",
      "actions": [
        "review_results",
        "approve",
        "publish",
        "withhold",
        "correct"
      ],
      "group": "Exam pipeline",
      "cols": [
        "national_rank",
        "state_rank",
        "school_rank",
        "percentage"
      ]
    },
    {
      "id": "OJ9",
      "title": "Generate certificates",
      "desc": "Issue and revoke certificates.",
      "icon": "file",
      "shape": "manage",
      "entity": "certificates",
      "scope": "all",
      "actions": [
        "issue",
        "revoke"
      ],
      "group": "Exam pipeline"
    },
    {
      "id": "OJ-RE",
      "title": "Re-evaluations",
      "desc": "Re-evaluation requests from schools — review, then resolve with a revised score + note, or reject.",
      "icon": "scale",
      "shape": "manage",
      "entity": "re_evaluations",
      "scope": "all",
      "actions": [
        "start_review",
        "resolve",
        "reject"
      ],
      "group": "Post-exam",
      "cols": [
        "re_eval_code",
        "result_id",
        "reason",
        "status",
        "revised_score"
