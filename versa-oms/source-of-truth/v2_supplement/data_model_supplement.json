{
  "_meta": {
    "purpose": "v2 SOURCE supplement — entities the BRD IMPLIED (via Directus) but never declared. There is NO Directus on v2; this declares our own identity table. Robot 1 (derive_specs) reads this alongside the BRD and maps the old 'directus_users' references to 'users'.",
    "frozen": "2026-06-26 — founder-approved (option A). The role list below is FROZEN here.",
    "auth_note": "The 'users' ENTITY is declared now so the data-model graph resolves. Its AUTH BEHAVIOUR (login, RBAC, sessions) is built LAST (auth-last). Declaring the entity is not building auth.",
    "directus_rename": {
      "directus_users": "users"
    },
    "source": "roles from company questionnaire Q11 + BRD sections 02 (Actors) / 03 (Roles)"
  },
  "workflow_entity": {
    "_purpose": "BRD §07 declares workflows but leaves the governed ENTITY implicit (entity column blank). This declares it as a SOURCE FACT so attribution is explicit, not a name-heuristic guess (which mis-attached student_registration to 'students' and left courier/evaluation unattached). Confirmed with founder 2026-06-27.",
    "_confirmed": "student_registration -> participations: a participation is the school's whole olympiad entry; a school runs MANY cycles at once so the roster cannot live on schools. students.participation_id links each roster row to it.",
    "_resolved": "Confirmed via §09 status-enum match + founder 2026-06-27: evaluation->omr_imports (scan import+review); exam_slot_booking->exam_slots (staff-predefined capacity); certificate_verification is a STATELESS public action (no entity lifecycle). The participation is the master spine (participation_status, 13 milestones) advanced by effects.",
    "_stateless_actions": [
      "certificate_verification"
    ],
    "school_onboarding": "schools",
    "student_registration": "participations",
    "payment_workflow": "payments",
    "exam_slot_booking": "exam_slots",
    "exam_material_release": "exam_materials",
    "courier_workflow": "courier_batches",
    "evaluation_workflow": "omr_imports",
    "result_publication": "results",
    "certificate_workflow": "certificates",
    "certificate_verification": "certificates",
    "import_processing": "school_imports",
    "campaign_lifecycle": "email_campaigns",
    "send_lifecycle": "email_sends"
  },
  "status_entity": {
    "_purpose": "BRD §09 declares status enums per concept but never linked them to entities (status fields had no enum). This maps each §09 concept to its entity so derive_specs attaches the authoritative enum. Validation then checks status against the §09 enum UNION the entity's workflow states (legitimate handoff states like school_onboarding's students_open).",
    "school_status": "schools",
    "participation_status": "participations",
    "payment_status": "payments",
    "exam_slot_status": "exam_slots",
    "exam_material_status": "exam_materials",
    "courier_status": "courier_batches",
    "evaluation_status": "omr_imports",
    "result_status": "results",
    "certificate_status": "certificates"
  },
  "generated_rules": {
    "_purpose": "Rules needing code generation beyond pure validators. candidate_id is auto-generated, unique + stable across finalisation (BRD §18 unit_candidate_id_generation). omr_candidate_match (BRD §10): every scanned candidate_id must exist in the participation roster and not be duplicated.",
    "auto_identifier": {
      "students": "candidate_id",
      "schools": "school_code"
    },
    "candidate_match": {
      "omr_imports": "students"
    }
  },
  "registration_creates_participation": {
    "_purpose": "BRD school_registration creates a school AND a participation record. When a school is converted (submit_registration: lead->registered), spin up its participation for the current olympiad @ students_open (the roster phase). Covers both entry doors (public SJ1 self-register, staff OJ2.1 create-lead) since both converge on submit_registration.",
    "trigger_entity": "schools",
    "trigger_action": "submit_registration",
    "creates": "participations",
    "status": "submitted"
  },
  "cascade_effects": {
    "_purpose": "One-to-many side effects: a transition on one entity advances ALL matching related records. AUTO-OPEN: when a school is approved, its participation(s) auto-open for student upload (students_open) — no manual staff step (was OJ2.4). A participation created while the school is already approved should likewise open on creation.",
    "schools.approve_school": {
      "target": "participations",
      "match": "school_id",
      "advance_to": "students_open"
    }
  },
  "participation_effects": {
    "_purpose": "EFFECT CHAINS — when an artifact stage completes, the participation spine (participation_status, 13 milestones from §09) auto-advances to this milestone, FORWARD-ONLY. The effect fires inside the artifact's transition; the participation is resolved via the artifact's FK (participation_id direct, or result_id->results.participation_id). slot_confirmed is reached by the participation's own booking action (exam_slots are shared capacity, no participation_id).",
    "payments.create_link": "payment_pending",
    "payments.webhook_paid": "paid",
    "payments.manual_confirm": "paid",
    "exam_materials.release_when_due": "materials_released",
    "omr_imports.approve_import": "exam_completed",
    "results.publish": "results_published",
    "certificates.issue": "certificates_released"
  },
  "transition_preconditions": {
    "_purpose": "Fields required before a transition. A directory PROSPECT can exist without a courier address; a school cannot submit_registration without it (courier labels).",
    "schools.submit_registration": [
      "address_line1",
      "locality",
      "pincode"
    ]
  },
  "service_hooks": {
    "_purpose": "A transition that calls a hand-written runtime KERNEL (integration). gen_services emits the call; the kernel is the signed/frozen module (plug-and-play).",
    "email_campaigns.start_send": {
      "import": "@/runtime/email/campaign_sender",
      "fn": "sendCampaign"
    },
    "email_campaigns.create_in_brevo": {
      "import": "@/runtime/email/campaign_brevo",
      "fn": "createInBrevo"
    }
  },
  "field_additions": {
    "_purpose": "Add fields to BRD-declared entities without §05 surgery (merged by derive_specs). OUTREACH/directory module.",
    "schools": [
      {
        "name": "website",
        "type": "string",
        "rule": "optional school website"
      },
      {
        "name": "source",
        "type": "enum",
        "rule": "system required acquisition source",
        "enum_values": [
          "import",
          "manual",
          "self"
        ]
      },
      {
        "name": "unsubscribed",
        "type": "boolean",
        "rule": "system outreach unsubscribe flag"
      },
      {
        "name": "last_contacted_at",
        "type": "timestamp",
        "rule": "system last campaign contact"
      },
      {
        "name": "import_id",
        "type": "uuid",
        "rule": "system source import batch (set for imported prospects)",
        "references": "school_imports",
        "cardinality": "many-to-one"
      }
    ]
  },
  "supplement_workflows": {
    "_purpose": "Lifecycles for the OUTREACH module entities (BRD §07 covers the olympiad pipeline; these are v2 additions). derive_catalog reads these like §07; the governed entity comes from workflow_entity above.",
    "import_processing": {
      "states": [
        "uploaded",
        "validating",
        "imported",
        "failed"
      ],
      "start": "uploaded",
      "success": "imported",
      "transitions": [
        {
          "action": "validate_rows",
          "from": "uploaded",
          "to": "validating"
        },
        {
          "action": "complete_import",
          "from": "validating",
          "to": "imported"
        },
        {
          "action": "fail_import",
          "from": "any",
          "to": "failed"
        }
      ]
    },
    "campaign_lifecycle": {
      "states": [
        "draft",
        "scheduled",
        "sending",
        "sent",
        "paused",
        "cancelled",
        "in_brevo"
      ],
      "start": "draft",
      "success": "sent",
      "transitions": [
        {
          "action": "schedule",
          "from": "draft",
          "to": "scheduled"
        },
        {
          "action": "start_send",
          "from": "draft",
          "to": "sending"
        },
        {
          "action": "finish_send",
          "from": "sending",
          "to": "sent"
        },
        {
          "action": "pause",
          "from": "sending",
          "to": "paused"
        },
        {
          "action": "cancel",
          "from": "any",
          "to": "cancelled"
        },
        {
          "action": "create_in_brevo",
          "from": "draft",
          "to": "in_brevo"
        }
      ]
    },
    "send_lifecycle": {
      "states": [
        "queued",
        "sent",
        "delivered",
        "opened",
        "clicked",
        "bounced",
        "unsubscribed",
        "failed"
      ],
      "start": "queued",
      "success": "delivered",
      "transitions": [
        {
          "action": "mark_sent",
          "from": "queued",
          "to": "sent"
        },
        {
          "action": "mark_delivered",
          "from": "sent",
          "to": "delivered"
        },
        {
          "action": "mark_opened",
          "from": "delivered",
          "to": "opened"
        },
        {
          "action": "mark_clicked",
          "from": "opened",
          "to": "clicked"
        },
        {
          "action": "mark_bounced",
          "from": "any",
          "to": "bounced"
        },
        {
          "action": "mark_unsubscribed",
          "from": "any",
          "to": "unsubscribed"
        },
        {
          "action": "mark_failed",
          "from": "any",
          "to": "failed"
        }
      ]
    }
  },
